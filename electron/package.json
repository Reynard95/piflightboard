{
  "name": "piflightboard-radar",
  "version": "1.0.0",
  "description": "PiFlightBoard radar desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.piflightboard.radar",
    "productName": "PiFlightBoard Radar",
    "files": ["main.js", "config.json"],
    "extraResources": [
      { "from": "../www", "to": "www" }
    ],
    "directories": {
      "output": "dist"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.0.0"
  }
}

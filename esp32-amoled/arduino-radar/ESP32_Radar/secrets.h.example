// secrets.h — local configuration, never committed to git
// Copy this file to secrets.h and fill in your values.

#pragma once

// ── WiFi ──────────────────────────────────────────────────────────────────────
const char* WIFI_SSID     = "YourNetworkName";
const char* WIFI_PASSWORD = "YourNetworkPassword";

// ── Pi (running readsb + lighttpd) ────────────────────────────────────────────
const char* PI_IP         = "192.168.x.x";   // local IP of your Pi
const int   PI_PORT       = 80;

// ── Receiver location ─────────────────────────────────────────────────────────
// Must match --lat / --lon in config/readsb.conf on the Pi.
// Used for distance and bearing calculations.
const float RECEIVER_LAT  = 0.0f;    // decimal degrees, e.g. 52.00818
const float RECEIVER_LON  = 0.0f;    // decimal degrees, e.g. 4.71261

// ── Time zone ─────────────────────────────────────────────────────────────────
// UTC offset in seconds: 3600 = UTC+1, 7200 = UTC+2, 0 = UTC
const long  TZ_OFFSET_SEC = 0;
